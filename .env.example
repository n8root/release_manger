# Конфигурация контейнеров (Docker Compose).
# Копировать в .env в корне проекта.
# Эти переменные используются только для запуска контейнеров (порты, БД, UID/GID).

# Права на файлы (Linux: id -u, id -g)
UID=1000
GID=1000

# Порт приложения на хосте
APP_PORT=8080

# PostgreSQL — создание контейнера и подключение приложения
# Значения должны совпадать с DB_* в laravel/.env при запуске в Docker
DB_DATABASE=release_manager
DB_USERNAME=release_manager
DB_PASSWORD=secret
